# FileMaker connection credentials — copy to .env and fill in (never commit .env)
FM_HOST=your-server.example.com
FM_DATABASE=YourDatabase
FM_USERNAME=api_service_account
FM_PASSWORD=

# Local-file patching accounts (used by fm-dc patch pipeline; FileMaker defaults shown)
FM_DEV_USER=Admin
FM_DEV_PASS=

# FileMaker Server ADMIN CONSOLE credentials (fm-admin skill: server status,
# hosted-file download). Different account than the file credentials above.
# Add more servers as FMS2_*, FMS3_*, … and select with --profile.
FMS_HOST=your-server.example.com
FMS_ADMIN_USER=
FMS_ADMIN_PASS=
