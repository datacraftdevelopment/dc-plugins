<?xml version="1.0" encoding="UTF-8"?>
<!--
  Agent_SaXML_Export v5 - paste-in half 2 of 2 (see the scaffold's
  workflow/02-install-the-export-script.md runbook).
  Whole-script paste into the Script Workspace script LIST, AFTER the SAXML
  table (saxml-table.xml) and a layout named SAXML exist - the steps resolve
  those names on paste. Ships with runFullAccess=True: Save a Copy as XML
  needs full-access privileges and the OData account should not hold them.
  Paste-ready; no placeholders.

  v5 over v4: no interview, no {{PLACEHOLDER}} substitution - the dedicated
  SAXML drop table travels with it. Logs the run row BEFORE exporting (a
  failed export still leaves a readable record), tracks Status/Stage/Error,
  and returns the row's primaryKey - the OData entity key for pickup.
-->
<fmxmlsnippet type="FMObjectList">
  <Script includeInMenu="True" SiriShortcutVisible="False" runFullAccess="True" id="246" name="Agent_SaXML_Export">
    <Step enable="True" id="89" name="# (comment)">
      <DisableStepCollapsed state="False"/>
      <Restore state="False"/>
      <Text>PURPOSE: export this file's own schema as Save-as-XML and hand it back to a coding agent over OData. Agent_SaXML_Export v5 (SAXML table). Exports catalog-selected Save-as-XML to the server temp folder, loads the result into SAXML::XMLDrop (container) and SAXML::ResponseText (text), and returns a JSON summary including the record's primaryKey.</Text>
    </Step>
    <Step enable="True" id="89" name="# (comment)">
      <DisableStepCollapsed state="False"/>
      <Restore state="False"/>
    </Step>
    <Step enable="True" id="89" name="# (comment)">
      <DisableStepCollapsed state="False"/>
      <Restore state="False"/>
      <Text>PARAMETER (JSON, all optional): {"runId":"...", "options":{"catalogs_included":[...],"include_details":true,"split_catalogs":false,"standalone_binarydata":false}}. Omit runId and one is generated. Omit options and the default catalog set below is used. RETURNS: {"ok":bool,"stage":"export|done","error":n,"runId":"...","primaryKey":"...","recordId":n,"chars":n,"path":"..."}.</Text>
    </Step>
    <Step enable="True" id="89" name="# (comment)">
      <DisableStepCollapsed state="False"/>
      <Restore state="False"/>
      <Text>PORTABILITY - to install this in another solution: (1) create a table AND table occurrence both named SAXML, with fields RunID, Status, Stage, ErrorCode, ErrorMessage, RequestJSON, ExportPath, XMLDrop (container), ResponseText, CharCount, plus the standard PrimaryKey / audit stamps; (2) create a layout named SAXML on that occurrence - it can be blank, Set Field does not need the fields placed on it; (3) paste this script and grant the OData account access to it. No custom functions and no plugins are used, so nothing else has to travel with it. Requires FileMaker 2026 (Save a Copy as XML, JSONMakeArray). Set RequestJSON / ExportPath / ResponseText to autoIndex OFF - ResponseText can hold tens of MB.</Text>
    </Step>
    <Step enable="True" id="89" name="# (comment)">
      <DisableStepCollapsed state="False"/>
      <Restore state="False"/>
    </Step>
    <Step enable="True" id="86" name="Set Error Capture">
      <Set state="True"/>
      <DisableStepCollapsed state="False"/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <DisableStepCollapsed state="False"/>
      <Value>
        <Calculation><![CDATA[Get ( ScriptParameter )]]></Calculation>
      </Value>
      <Repetition>
        <Calculation><![CDATA[1]]></Calculation>
      </Repetition>
      <Name>$param</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <DisableStepCollapsed state="False"/>
      <Value>
        <Calculation><![CDATA[Let ( r = JSONGetElement ( $param ; "runId" ) ; If ( IsEmpty ( r ) or r = "?" ; Get ( UUID ) ; r ) )]]></Calculation>
      </Value>
      <Repetition>
        <Calculation><![CDATA[1]]></Calculation>
      </Repetition>
      <Name>$runId</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <DisableStepCollapsed state="False"/>
      <Value>
        <Calculation><![CDATA[Let ( [
	o = JSONGetElement ( $param ; "options" ) ;
	fallback = JSONSetElement ( "{}" ;
		[ "catalogs_included" ; JSONMakeArray (
				"BaseTableCatalog FieldCatalog TableOccurrenceCatalog RelationshipCatalog CustomFunctionsCatalog ValueListCatalog ScriptCatalog LayoutCatalog Metadata"
				; " " ; JSONString ) ; JSONArray ] ;
		[ "include_details" ; True ; JSONBoolean ] ;
		[ "split_catalogs" ; False ; JSONBoolean ] ;
		[ "standalone_binarydata" ; False ; JSONBoolean ]
	)
] ;
	If ( IsEmpty ( o ) or o = "?" ; fallback ; o )
)]]></Calculation>
      </Value>
      <Repetition>
        <Calculation><![CDATA[1]]></Calculation>
      </Repetition>
      <Name>$options</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <DisableStepCollapsed state="False"/>
      <Value>
        <Calculation><![CDATA[Get ( TemporaryPath ) & "saxml_" & $runId & ".xml"]]></Calculation>
      </Value>
      <Repetition>
        <Calculation><![CDATA[1]]></Calculation>
      </Repetition>
      <Name>$fmPath</Name>
    </Step>
    <Step enable="True" id="89" name="# (comment)">
      <DisableStepCollapsed state="False"/>
      <Restore state="False"/>
      <Text>Create the log row first, so a failed export still leaves something to read over OData.</Text>
    </Step>
    <Step enable="True" id="6" name="Go to Layout">
      <DisableStepCollapsed state="False"/>
      <LayoutDestination value="SelectedLayout"/>
      <Layout id="91" name="SAXML"/>
    </Step>
    <Step enable="True" id="7" name="New Record/Request">
      <DisableStepCollapsed state="False"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA[$runId]]></Calculation>
      <Field table="SAXML" id="8" name="RunID"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA[$param]]></Calculation>
      <Field table="SAXML" id="13" name="RequestJSON"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA[$fmPath]]></Calculation>
      <Field table="SAXML" id="14" name="ExportPath"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA["running"]]></Calculation>
      <Field table="SAXML" id="9" name="Status"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA["export"]]></Calculation>
      <Field table="SAXML" id="10" name="Stage"/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <DisableStepCollapsed state="False"/>
      <Value>
        <Calculation><![CDATA[SAXML::PrimaryKey]]></Calculation>
      </Value>
      <Repetition>
        <Calculation><![CDATA[1]]></Calculation>
      </Repetition>
      <Name>$pk</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <DisableStepCollapsed state="False"/>
      <Value>
        <Calculation><![CDATA[Get ( RecordID )]]></Calculation>
      </Value>
      <Repetition>
        <Calculation><![CDATA[1]]></Calculation>
      </Repetition>
      <Name>$recId</Name>
    </Step>
    <Step enable="True" id="75" name="Commit Records/Requests">
      <NoInteract state="True"/>
      <Option state="False"/>
      <ESSForceCommit state="False"/>
      <DisableStepCollapsed state="False"/>
    </Step>
    <Step enable="True" id="89" name="# (comment)">
      <DisableStepCollapsed state="False"/>
      <Restore state="False"/>
      <Text>Export the schema copy. split_catalogs must stay False - this reads back a single file.</Text>
    </Step>
    <Step enable="True" id="3" name="Save a Copy as XML">
      <Option state="False"/>
      <OutputEntireBinaryData state="False"/>
      <SpecifyJSONOptions state="True"/>
      <DisableStepCollapsed state="False"/>
      <UniversalPathList>$fmPath</UniversalPathList>
      <SaXML>
        <JSONOptions>
          <Calculation><![CDATA[$options]]></Calculation>
        </JSONOptions>
      </SaXML>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <DisableStepCollapsed state="False"/>
      <Value>
        <Calculation><![CDATA[Get ( LastError )]]></Calculation>
      </Value>
      <Repetition>
        <Calculation><![CDATA[1]]></Calculation>
      </Repetition>
      <Name>$exportErr</Name>
    </Step>
    <Step enable="True" id="68" name="If">
      <DisableStepCollapsed state="False"/>
      <Restore state="False"/>
      <Calculation><![CDATA[$exportErr <> 0]]></Calculation>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA["error"]]></Calculation>
      <Field table="SAXML" id="9" name="Status"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA[$exportErr]]></Calculation>
      <Field table="SAXML" id="11" name="ErrorCode"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA["Save a Copy as XML failed. Check that the account running this script has Full Access or explicit permission to save a copy, and that the options JSON is valid."]]></Calculation>
      <Field table="SAXML" id="12" name="ErrorMessage"/>
    </Step>
    <Step enable="True" id="75" name="Commit Records/Requests">
      <NoInteract state="True"/>
      <Option state="False"/>
      <ESSForceCommit state="False"/>
      <DisableStepCollapsed state="False"/>
    </Step>
    <Step enable="True" id="6" name="Go to Layout">
      <DisableStepCollapsed state="False"/>
      <LayoutDestination value="OriginalLayout"/>
    </Step>
    <Step enable="True" id="103" name="Exit Script">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "ok" ; False ; JSONBoolean ] ;
	[ "stage" ; "export" ; JSONString ] ;
	[ "error" ; $exportErr ; JSONNumber ] ;
	[ "runId" ; $runId ; JSONString ] ;
	[ "primaryKey" ; $pk ; JSONString ] ;
	[ "recordId" ; $recId ; JSONNumber ] ;
	[ "path" ; $fmPath ; JSONString ]
)]]></Calculation>
    </Step>
    <Step enable="True" id="70" name="End If">
      <DisableStepCollapsed state="False"/>
    </Step>
    <Step enable="True" id="89" name="# (comment)">
      <DisableStepCollapsed state="False"/>
      <Restore state="False"/>
      <Text>Read the exported file back off disk into the record.</Text>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA["read"]]></Calculation>
      <Field table="SAXML" id="10" name="Stage"/>
    </Step>
    <Step enable="True" id="160" name="Insert from URL">
      <NoInteract state="True"/>
      <DontEncodeURL state="False"/>
      <SelectAll state="True"/>
      <DisableStepCollapsed state="False"/>
      <VerifySSLCertificates state="False"/>
      <Calculation><![CDATA[ConvertFromFileMakerPath ( $fmPath ; URLPath )]]></Calculation>
      <Text/>
      <Field>$xmlBlob</Field>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <DisableStepCollapsed state="False"/>
      <Value>
        <Calculation><![CDATA[Get ( LastError )]]></Calculation>
      </Value>
      <Repetition>
        <Calculation><![CDATA[1]]></Calculation>
      </Repetition>
      <Name>$insertErr</Name>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA[$xmlBlob]]></Calculation>
      <Field table="SAXML" id="15" name="XMLDrop"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA[Let ( t = TextDecode ( $xmlBlob ; "utf-8" ) ; If ( IsEmpty ( t ) ; $xmlBlob ; t ) )]]></Calculation>
      <Field table="SAXML" id="16" name="ResponseText"/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <DisableStepCollapsed state="False"/>
      <Value>
        <Calculation><![CDATA[Length ( SAXML::ResponseText )]]></Calculation>
      </Value>
      <Repetition>
        <Calculation><![CDATA[1]]></Calculation>
      </Repetition>
      <Name>$chars</Name>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA[$chars]]></Calculation>
      <Field table="SAXML" id="17" name="CharCount"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA[$insertErr]]></Calculation>
      <Field table="SAXML" id="11" name="ErrorCode"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA[If ( $insertErr <> 0 or $chars = 0 ; "error" ; "done" )]]></Calculation>
      <Field table="SAXML" id="9" name="Status"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA[Case (
	$insertErr <> 0 ; "Could not read the exported file back from " & $fmPath ;
	$chars = 0 ; "The export ran but the file read back empty. Check server temp folder permissions." ;
	""
)]]></Calculation>
      <Field table="SAXML" id="12" name="ErrorMessage"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA["done"]]></Calculation>
      <Field table="SAXML" id="10" name="Stage"/>
    </Step>
    <Step enable="True" id="75" name="Commit Records/Requests">
      <NoInteract state="True"/>
      <Option state="False"/>
      <ESSForceCommit state="False"/>
      <DisableStepCollapsed state="False"/>
    </Step>
    <Step enable="True" id="6" name="Go to Layout">
      <DisableStepCollapsed state="False"/>
      <LayoutDestination value="OriginalLayout"/>
    </Step>
    <Step enable="True" id="103" name="Exit Script">
      <DisableStepCollapsed state="False"/>
      <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "ok" ; If ( $insertErr = 0 and $chars > 0 ; True ; False ) ; JSONBoolean ] ;
	[ "stage" ; "done" ; JSONString ] ;
	[ "error" ; $insertErr ; JSONNumber ] ;
	[ "runId" ; $runId ; JSONString ] ;
	[ "primaryKey" ; $pk ; JSONString ] ;
	[ "recordId" ; $recId ; JSONNumber ] ;
	[ "chars" ; $chars ; JSONNumber ] ;
	[ "path" ; $fmPath ; JSONString ]
)]]></Calculation>
    </Step>
  </Script>
</fmxmlsnippet>
